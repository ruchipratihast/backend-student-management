          }
        },
        "additionalProperties": false
      },
      "StudentRequest": {
        "type": "object",
        "properties": {
          "fullName": {
            "type": "string",
            "nullable": true
          },
          "birthday": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "courseId": {
            "type": "string",
            "format": "uuid"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "tags": [
    {
      "name": "Course"
    },
    {
      "name": "Students"
    }
  ]
